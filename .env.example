
# ──────────────────────────────────────────────────────────── For local cognee sdk build ────────────────────────────────────────────────────────────

# Free Local Embedding Interface
# EMBEDDING_PROVIDER="fastembed"
# EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"

# VECTOR_DB_PROVIDER=lancedb
# GRAPH_DATABASE_PROVIDER=kuzu

# ── Gemini ─────────────────────────────────────────────────────────────
# Enable the built-in client-side throttling
LLM_RATE_LIMIT_ENABLED=true

# Cap it at 60 requests (adjust based on your provider's Tier limit)
LLM_RATE_LIMIT_REQUESTS=1

# The time window in seconds (60 seconds = 1 minute)
LLM_RATE_LIMIT_INTERVAL=4
LITELLM_NUM_RETRIES=8

LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-3.1-flash-lite
LLM_API_KEY=
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-2





# ──────────────────────────────────────────────────────────── Cognee Cloud build ────────────────────────────────────────────────────────────

COGNEE_API_KEY=
COGNEE_SERVICE_URL=
COGNEE_DATASET=dental_insurance_kb_1


# ── Supabase (free) ──────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=  # Settings > API > Secret key

# ── JWT (any random string) ──────────────────────────────────────────────────
JWT_SECRET= # long random character string


# ── Session config ───────────────────────────────────────────────────────────
SESSION_TTL_SECONDS=604800 # 7-days auto delete
SESSION_ABANDON_AFTER_SECONDS=31536000
AUTO_FEEDBACK=false
SELF_IMPROVEMENT=false # true for graph build, false for temporary chat session management